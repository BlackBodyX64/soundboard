<Window x:Class="TikTokSoundboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🎵 TikTok Soundboard"
        Width="1280" Height="720"
        MinWidth="1100" MinHeight="620"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        Icon="pack://application:,,,/icon.ico">

    <Window.Resources>
        <!-- Flat button style -->
        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8b949e"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="4" Margin="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1Affffff"/>
                                <Setter Property="Foreground" Value="#f0f6fc"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="4" Margin="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle switch style -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="#c9d1d9" FontSize="13" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Border x:Name="Track" Width="44" Height="24"
                                    CornerRadius="12" Background="#21262d"
                                    BorderBrush="#30363d" BorderThickness="1.5">
                                <Ellipse x:Name="Thumb" Width="16" Height="16"
                                         Fill="#8b949e" HorizontalAlignment="Left" Margin="2,0,0,0">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform x:Name="ThumbTranslate" X="0"/>
                                    </Ellipse.RenderTransform>
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.3"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Border>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#e94560"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="#e94560"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="White"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ThumbTranslate" Storyboard.TargetProperty="X">
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="21">
                                                    <EasingDoubleKeyFrame.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseOut"/>
                                                    </EasingDoubleKeyFrame.EasingFunction>
                                                </EasingDoubleKeyFrame>
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ThumbTranslate" Storyboard.TargetProperty="X">
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="0">
                                                    <EasingDoubleKeyFrame.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseOut"/>
                                                    </EasingDoubleKeyFrame.EasingFunction>
                                                </EasingDoubleKeyFrame>
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section label style -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#6e7681"/>
            <Setter Property="Margin" Value="10,6,0,8"/>
        </Style>

        <!-- Slider style for volume -->
        <Style x:Key="VolumeSlider" TargetType="Slider">
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="TickFrequency" Value="1"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" ClipToBounds="True" Margin="10">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0A0E14" Offset="0"/>
                <GradientStop Color="#131822" Offset="0.5"/>
                <GradientStop Color="#1A202C" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <!-- A subtle inner border for glass effect -->
        <Border BorderBrush="#1Affffff" BorderThickness="1" CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>  <!-- Title bar -->
                    <RowDefinition Height="50"/>  <!-- Header -->
                    <RowDefinition Height="46"/>  <!-- Volume bar -->
                    <RowDefinition Height="*"/>   <!-- Content -->
                </Grid.RowDefinitions>

                <!-- ===== Title Bar ===== -->
                <Border Grid.Row="0" Background="#40000000"
                        BorderBrush="#10ffffff" BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="OnTitleBarDrag">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                            <TextBlock Text="🎵" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="TikTok Soundboard" FontSize="13" FontWeight="Bold"
                                       Foreground="#e6edf3" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="4,0">
                            <Button Content="─" Width="42" Height="32"
                                    Style="{StaticResource FlatButton}"
                                    Click="OnMinimizeClick"/>
                            <Button Content="☐" Width="42" Height="32"
                                    Style="{StaticResource FlatButton}"
                                    Click="OnMaximizeClick"/>
                            <Button Content="✕" Width="42" Height="32"
                                    Style="{StaticResource CloseButton}"
                                    Click="OnCloseClick"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ===== Header ===== -->
                <Border Grid.Row="1" Background="#15ffffff"
                        BorderBrush="#08ffffff" BorderThickness="0,0,0,1">
                    <Grid Margin="20,0">
                        <!-- Stop All button -->
                        <Button HorizontalAlignment="Left" VerticalAlignment="Center"
                                Padding="16,8" Click="OnStopAllClick" Cursor="Hand"
                                FontFamily="Segoe UI" FontSize="13" FontWeight="Bold"
                                Foreground="White" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" CornerRadius="6" Background="{TemplateBinding Background}">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#da3633" BlurRadius="10" ShadowDepth="0" Opacity="0.4"/>
                                        </Border.Effect>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background">
                                                <Setter.Value>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#ed4643" Offset="0"/>
                                                        <GradientStop Color="#d13838" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#b92d2d"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#da3633" Offset="0"/>
                                    <GradientStop Color="#b92d2d" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⏹" Margin="0,0,6,0"/>
                                <TextBlock Text="STOP ALL AUDIO"/>
                            </StackPanel>
                        </Button>

                        <!-- Hotkey toggle -->
                        <CheckBox x:Name="HotkeyToggle" Content="Global Hotkeys"
                                  IsChecked="True" HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Style="{StaticResource ToggleSwitch}"
                                  Checked="OnHotkeyToggle" Unchecked="OnHotkeyToggle"/>
                    </Grid>
                </Border>

                <!-- ===== Volume Bar ===== -->
                <Border Grid.Row="2" Background="#0Affffff"
                        BorderBrush="#08ffffff" BorderThickness="0,0,0,1">
                    <Grid Margin="20,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🔊" FontSize="18" Foreground="#8b949e" VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#8b949e" BlurRadius="10" ShadowDepth="0" Opacity="0.3"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <Slider x:Name="MasterVolumeSlider" Style="{StaticResource VolumeSlider}"
                                    Value="80" ValueChanged="OnMasterVolumeChanged"/>
                            <TextBlock x:Name="MasterVolumeLabel" Text="80%"
                                       FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                       Foreground="#e94560" VerticalAlignment="Center"
                                       Margin="12,0,0,0" Width="40" TextAlignment="Right"/>
                        </StackPanel>

                        <TextBlock Text="✨ 🎧 ลากไฟล์เสียงวางบนปุ่ม  |  คลิกขวาตั้งค่า"
                                   FontFamily="Segoe UI" FontSize="11" FontWeight="Medium"
                                   Foreground="#7d8590" HorizontalAlignment="Right"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- ===== Main Content ===== -->
                <Grid Grid.Row="3" Margin="14,12,14,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Keyboard -->
                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Margin="0,0,14,0">
                        <StackPanel x:Name="KeyboardPanel"/>
                    </ScrollViewer>

                    <!-- Right: Numpad -->
                    <Border Grid.Column="1" Background="#0Affffff" CornerRadius="12"
                            BorderBrush="#10ffffff" BorderThickness="1"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="NUMPAD" Style="{StaticResource SectionLabel}" HorizontalAlignment="Center" Margin="0,10,0,16"/>
                            <StackPanel x:Name="NumpadPanel"
                                        VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
