<Window x:Class="TikTokSoundboard.Controls.KeyPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="เลือกปุ่มเป้าหมาย"
        Width="500" Height="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0d1117"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border CornerRadius="10" Background="#0d1117" ClipToBounds="True"
            BorderBrush="#30363d" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="#161b22" Padding="16,10" CornerRadius="10,10,0,0">
                <Grid>
                    <TextBlock Text="📦 เลือกปุ่มที่จะย้ายเสียงไป"
                               FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"
                               Foreground="#c9d1d9" VerticalAlignment="Center"/>
                    <Button Content="✕" HorizontalAlignment="Right" Width="28" Height="28"
                            Background="Transparent" Foreground="#8b949e" BorderThickness="0"
                            Click="OnCloseClick" Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- Keys Grid -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="15,15,15,15">
                    <TextBlock Text="FUNCTION KEYS" Foreground="#484f58" FontSize="11"
                               FontWeight="Bold" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                    <WrapPanel x:Name="FKeyPanel" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                    <TextBlock Text="MAIN KEYBOARD" Foreground="#484f58" FontSize="11"
                               FontWeight="Bold" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                    <StackPanel x:Name="KbRowsPanel" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                    <TextBlock Text="NUMPAD" Foreground="#484f58" FontSize="11"
                               FontWeight="Bold" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                    <StackPanel x:Name="NumpadPanel" HorizontalAlignment="Center"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>