<UserControl x:Class="TikTokSoundboard.Controls.KeyButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             AllowDrop="True"
             MouseLeftButtonDown="OnLeftClick"
             MouseRightButtonDown="OnRightClick"
             DragEnter="OnDragEnter"
             DragLeave="OnDragLeave"
             Drop="OnDrop"
             Margin="3">

    <Grid Width="{Binding ButtonWidth, ElementName=Root}" Height="{Binding ButtonHeight, ElementName=Root}">
        <Border x:Name="OuterBorder"
                CornerRadius="8"
                BorderThickness="1.5"
                BorderBrush="#30363d"
                Background="#21262d"
                Cursor="Hand"
                RenderTransformOrigin="0.5,0.5">
            <Border.Effect>
                <DropShadowEffect x:Name="ShadowEffect" Color="Black" BlurRadius="5" ShadowDepth="2" Opacity="0.3"/>
            </Border.Effect>
            <Border.RenderTransform>
                <TranslateTransform x:Name="HoverTranslate" Y="0"/>
            </Border.RenderTransform>

            <Grid>
                <!-- Subtle internal top highlight for 3D effect -->
                <Border CornerRadius="7" BorderThickness="0,1,0,0" BorderBrush="#15ffffff" Margin="1"/>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-2,0,0">
                    <TextBlock x:Name="KeyLabel"
                               Text="{Binding DisplayText, ElementName=Root}"
                               FontFamily="Segoe UI Semibold"
                               FontSize="14"
                               Foreground="#8b949e"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="SoundNameLabel"
                               Text=""
                               FontFamily="Segoe UI"
                               FontSize="9"
                               Foreground="#6e7681"
                               HorizontalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="60"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Indicator bar -->
                <Border x:Name="Indicator"
                        Height="4"
                        CornerRadius="2"
                        Background="#30363d"
                        VerticalAlignment="Bottom"
                        Margin="10,0,10,6">
                    <Border.Effect>
                        <DropShadowEffect x:Name="IndicatorGlow" Color="Transparent" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
                    </Border.Effect>
                </Border>
            </Grid>
        </Border>
    </Grid>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="MouseEnter">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="HoverTranslate" Storyboard.TargetProperty="Y">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.15" Value="-3">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <QuadraticEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ShadowEffect" Storyboard.TargetProperty="BlurRadius">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.15" Value="15"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ShadowEffect" Storyboard.TargetProperty="ShadowDepth">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.15" Value="5"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ShadowEffect" Storyboard.TargetProperty="Opacity">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.15" Value="0.6"/>
                    </DoubleAnimationUsingKeyFrames>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
        <EventTrigger RoutedEvent="MouseLeave">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="HoverTranslate" Storyboard.TargetProperty="Y">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="0">
                            <EasingDoubleKeyFrame.EasingFunction>
                                <QuadraticEase EasingMode="EaseOut"/>
                            </EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ShadowEffect" Storyboard.TargetProperty="BlurRadius">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="5"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ShadowEffect" Storyboard.TargetProperty="ShadowDepth">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="2"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ShadowEffect" Storyboard.TargetProperty="Opacity">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="0.3"/>
                    </DoubleAnimationUsingKeyFrames>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
</UserControl>
