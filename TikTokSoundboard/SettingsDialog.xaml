<Window x:Class="TikTokSoundboard.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ตั้งค่า"
        Width="400" Height="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0d1117"
        WindowStyle="None"
        AllowsTransparency="True"
        BorderBrush="#30363d"
        BorderThickness="1"
        Icon="pack://application:,,,/icon.ico">

    <Border CornerRadius="10" Background="#0d1117" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#161b22" Padding="16,10"
                    MouseLeftButtonDown="OnTitleBarDrag" CornerRadius="10,10,0,0">
                <Grid>
                    <TextBlock x:Name="TitleText"
                               Text="⚙ ตั้งค่าปุ่ม"
                               FontFamily="Segoe UI"
                               FontSize="16" FontWeight="Bold"
                               Foreground="#e94560"/>
                    <Button Content="✕" HorizontalAlignment="Right"
                            Width="28" Height="28"
                            Background="Transparent" Foreground="#8b949e"
                            BorderThickness="0" FontSize="14"
                            Click="OnCloseClick" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#f85149"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Body -->
            <StackPanel Grid.Row="1" Margin="20,12">
                <!-- File -->
                <TextBlock Text="ไฟล์เสียง:" Foreground="#c9d1d9" FontSize="11"
                           FontFamily="Segoe UI" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="FilePathBox" Grid.Column="0"
                             Background="#161b22" Foreground="#c9d1d9"
                             BorderBrush="#30363d" FontFamily="Segoe UI" FontSize="12"
                             Padding="6,4" VerticalContentAlignment="Center"/>
                    <Button Grid.Column="1" Content="📂" Width="34" Height="28"
                            Margin="4,0,0,0" Background="#30363d" Foreground="#c9d1d9"
                            BorderBrush="#484f58" BorderThickness="1" Cursor="Hand"
                            Click="OnBrowseClick"/>
                </Grid>

                <!-- Display Name -->
                <TextBlock Text="ชื่อแสดง:" Foreground="#c9d1d9" FontSize="11"
                           FontFamily="Segoe UI" FontWeight="SemiBold" Margin="0,10,0,4"/>
                <TextBox x:Name="DisplayNameBox"
                         Background="#161b22" Foreground="#c9d1d9"
                         BorderBrush="#30363d" FontFamily="Segoe UI" FontSize="12"
                         Padding="6,4" VerticalContentAlignment="Center"/>

                <!-- Volume -->
                <TextBlock Text="Volume:" Foreground="#c9d1d9" FontSize="11"
                           FontFamily="Segoe UI" FontWeight="SemiBold" Margin="0,10,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="VolumeSlider" Grid.Column="0"
                            Minimum="0" Maximum="100" Value="100"
                            TickFrequency="1" IsSnapToTickEnabled="True"
                            ValueChanged="OnVolumeChanged"/>
                    <TextBlock x:Name="VolumeLabel" Grid.Column="1"
                               Text="100%" Foreground="#c9d1d9"
                               FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>

            <!-- Buttons -->
            <Grid Grid.Row="2" Margin="20,0,20,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="💾 บันทึก" Height="36"
                        FontFamily="Segoe UI" FontSize="13" FontWeight="Bold"
                        Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="OnSaveClick">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#238636" Offset="0"/>
                            <GradientStop Color="#1a7f37" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

                <Button Grid.Column="2" Content="🗑 ล้าง" Height="36"
                        FontFamily="Segoe UI" FontSize="13" FontWeight="Bold"
                        Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="OnClearClick">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#da3633" Offset="0"/>
                            <GradientStop Color="#b92d2d" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
