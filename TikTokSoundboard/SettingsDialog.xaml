<Window x:Class="TikTokSoundboard.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:TikTokSoundboard.Controls"
        Title="ตั้งค่า"
        Width="540" Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0d1117"
        WindowStyle="None"
        AllowsTransparency="True"
        Icon="pack://application:,,,/icon.ico">

    <Window.Resources>
        <!-- Flat icon-button style -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#8b949e"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1Affffff"/>
                                <Setter Property="Foreground" Value="#f0f6fc"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#30ffffff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10" Background="#0d1117" ClipToBounds="True"
            BorderBrush="#30363d" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- title bar -->
                <RowDefinition Height="*"/>       <!-- body (scrollable) -->
                <RowDefinition Height="Auto"/>    <!-- action buttons -->
            </Grid.RowDefinitions>

            <!-- ===== Title Bar ===== -->
            <Border Grid.Row="0" Background="#161b22" Padding="16,10"
                    MouseLeftButtonDown="OnTitleBarDrag" CornerRadius="10,10,0,0">
                <Grid>
                    <TextBlock x:Name="TitleText" Text="⚙ ตั้งค่าปุ่ม"
                               FontFamily="Segoe UI" FontSize="16" FontWeight="Bold"
                               Foreground="#e94560"/>
                    <Button Content="✕" HorizontalAlignment="Right"
                            Width="28" Height="28"
                            Background="Transparent" Foreground="#8b949e"
                            BorderThickness="0" FontSize="14"
                            Click="OnCloseClick" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#f85149"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- ===== Body ===== -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="20,14,20,4">

                    <!-- File picker row -->
                    <TextBlock Text="ไฟล์เสียง:" Foreground="#c9d1d9" FontSize="13"
                               FontFamily="Segoe UI" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="FilePathBox" Grid.Column="0"
                                 Background="#161b22" Foreground="#c9d1d9"
                                 BorderBrush="#30363d" FontFamily="Segoe UI" FontSize="13"
                                 Padding="6,4" VerticalContentAlignment="Center"
                                 TextChanged="OnFilePathChanged"/>
                        <Button Grid.Column="1" Content="📂" Width="34" Height="28"
                                Margin="4,0,0,0" Background="#30363d" Foreground="#c9d1d9"
                                BorderBrush="#484f58" BorderThickness="1" Cursor="Hand"
                                Click="OnBrowseClick"/>
                    </Grid>

                    <!-- ─── Waveform + playback ─── -->
                    <Border Margin="0,12,0,0" CornerRadius="8" ClipToBounds="True"
                            BorderBrush="#30363d" BorderThickness="1">
                        <ctrl:WaveformViewer x:Name="Waveform" Height="100"/>
                    </Border>

                    <!-- Trim time labels -->
                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="◀ " Foreground="#ffd700" FontSize="10"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="StartTimeLabel" Text="0.00 s"
                                       Foreground="#ffd700" FontFamily="Consolas" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" x:Name="DurationLabel" Text="— ไม่มีไฟล์ —"
                                   Foreground="#484f58" FontFamily="Segoe UI" FontSize="13"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <TextBlock x:Name="EndTimeLabel" Text="0.00 s"
                                       Foreground="#ffd700" FontFamily="Consolas" FontSize="12"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text=" ▶" Foreground="#ffd700" FontSize="10"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Playback controls + reset trim -->
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Play -->
                        <Button x:Name="PlayBtn" Grid.Column="0"
                                Width="36" Height="36" Padding="0"
                                Background="#238636" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                ToolTip="เล่นเสียงตามจุด Trim ที่กำหนด"
                                Click="OnPlayClick">
                            <TextBlock Text="▶" FontSize="15"/>
                        </Button>

                        <!-- Stop -->
                        <Button x:Name="StopBtn" Grid.Column="1"
                                Width="36" Height="36" Padding="0" Margin="6,0,0,0"
                                Background="#30363d" Foreground="#c9d1d9"
                                BorderThickness="0" Cursor="Hand"
                                ToolTip="หยุดเสียง"
                                Click="OnStopClick">
                            <TextBlock Text="⏹" FontSize="14"/>
                        </Button>

                        <!-- Playback status -->
                        <TextBlock x:Name="PlayStatusLabel" Grid.Column="2"
                                   Text="" Foreground="#8b949e" FontFamily="Segoe UI"
                                   FontSize="13" VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>

                        <!-- Reset trim -->
                        <Button x:Name="ResetTrimBtn" Grid.Column="3"
                                Content="↺ รีเซ็ต Trim"
                                Height="28" Padding="8,0"
                                FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                Foreground="#8b949e" Background="Transparent"
                                BorderBrush="#30363d" BorderThickness="1" Cursor="Hand"
                                Click="OnResetTrimClick" Visibility="Collapsed">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#c9d1d9"/>
                                            <Setter Property="BorderBrush" Value="#484f58"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                    <!-- Display Name -->
                    <TextBlock Text="ชื่อแสดง:" Foreground="#c9d1d9" FontSize="13"
                               FontFamily="Segoe UI" FontWeight="SemiBold" Margin="0,14,0,4"/>
                    <TextBox x:Name="DisplayNameBox"
                             Background="#161b22" Foreground="#c9d1d9"
                             BorderBrush="#30363d" FontFamily="Segoe UI" FontSize="13"
                             Padding="6,4" VerticalContentAlignment="Center"/>

                    <!-- Volume -->
                    <TextBlock Text="Volume:" Foreground="#c9d1d9" FontSize="13"
                               FontFamily="Segoe UI" FontWeight="SemiBold" Margin="0,10,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="42"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="VolumeSlider" Grid.Column="0"
                                Minimum="0" Maximum="100" Value="100"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="OnVolumeChanged"/>
                        <TextBlock x:Name="VolumeLabel" Grid.Column="1"
                                   Text="100%" Foreground="#c9d1d9"
                                   FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <!-- ===== Action buttons ===== -->
            <Grid Grid.Row="2" Margin="20,10,20,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="💾 บันทึก" Height="42"
                        FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"
                        Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="OnSaveClick">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#238636" Offset="0"/>
                            <GradientStop Color="#1a7f37" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
                <Button Grid.Column="2" Content="🗑 ล้าง" Height="42"
                        FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"
                        Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="OnClearClick">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#da3633" Offset="0"/>
                            <GradientStop Color="#b92d2d" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
