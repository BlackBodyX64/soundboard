<Window x:Class="TikTokSoundboard.UrlInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ใส่ URL"
        Width="440" Height="160"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="pack://application:,,,/icon.ico">

    <Border CornerRadius="10" Background="#161b22" BorderBrush="#30363d" BorderThickness="1"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <Border Grid.Row="0" Background="#0d1117" Padding="14,9"
                    MouseLeftButtonDown="OnDrag" CornerRadius="10,10,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📥 " FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock Text="ใส่ URL YouTube หรือ TikTok"
                               Foreground="#58a6ff" FontFamily="Segoe UI"
                               FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- URL Box -->
            <TextBox x:Name="UrlBox" Grid.Row="1" Margin="14,12,14,0"
                     Background="#0d1117" Foreground="#c9d1d9"
                     BorderBrush="#30363d" FontFamily="Segoe UI" FontSize="12"
                     Padding="8,6" VerticalContentAlignment="Center"
                     CaretBrush="#58a6ff"
                     Text="" GotFocus="OnUrlBoxFocus"
                     KeyDown="OnKeyDown"/>

            <!-- Buttons -->
            <Grid Grid.Row="2" Margin="14,10,14,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="✅ ยืนยัน" Height="32"
                        FontFamily="Segoe UI" FontSize="12" FontWeight="Bold"
                        Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="OnConfirmClick">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#238636" Offset="0"/>
                            <GradientStop Color="#1a7f37" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
                <Button Grid.Column="2" Content="ยกเลิก" Height="32" Width="72"
                        FontFamily="Segoe UI" FontSize="12"
                        Foreground="#c9d1d9" Background="#30363d"
                        BorderThickness="0" Cursor="Hand"
                        Click="OnCancelClick"/>
            </Grid>
        </Grid>
    </Border>
</Window>
